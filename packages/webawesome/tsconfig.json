{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,

    "removeComments": true,

    "noImplicitAny": true,

    "declarationMap": true,

    "jsx": "react-native",
    "jsxImportSource": "jsx-forge",

    "plugins": [
      // {
      //   "name": "web-elements-analyzer",
      //   "persist": {
      //     "typings": true,
      //     "externalsTypings": true,
      //     "customElementsManifest": true
      //   }
      // },
      {
        "transform": "jsx-forge/transform"
        // "defaultHtmlFlavor": "signal"
      },
      {
        "transform": "@lit/ts-transformers",
        "import": "idiomaticDecoratorsTransformer"
      }
    ]
  },
  "include": [
    //
    "src"
  ],
  "exclude": ["src/styles.ts", "src/react.ts"]
}
