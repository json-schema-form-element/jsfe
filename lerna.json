{
  "$schema": "./node_modules/lerna/schemas/lerna-schema.json",
  "version": "independent",
  "npmClient": "pnpm",
  "command": {
    "publish": {
      "message": "chore: publish release"
    }
  },
  "ignoreChanges": [
    "*.md",
    "**/test/**",
    "pnpm-lock.yaml",
    "pnpm-workspace.yaml",
    "turbo.json",
    "eslint.config.js",
    "tsconfig.json",
    "typedoc*.json*",
    "local-ci.sh",
    "scripts/**",
    "starter-projects/**"
  ],
  "packages": [
    //
    "./packages/engine",
    "./packages/generics",
    "./packages/webawesome"
  ]
}
