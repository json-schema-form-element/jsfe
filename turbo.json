{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },

    "clean": {
      "dependsOn": ["^clean"],
      "outputs": []
    },
    "dev": {
      "dependsOn": ["^scss:dev"],
      "cache": false,
      "persistent": true
    }
  }
}
