{
  "name": "@jsfe/webawesome",
  "version": "0.4.0",
  "description": "Web Awesome forms, auto-generated by JSON schemas.",
  "keywords": [
    "json-schema",
    "web-awesome",
    "forms",
    "generation",
    "declarative",
    "openapi",
    "mongodb",
    "page-builder"
  ],
  "homepage": "https://jsfe.js.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/json-schema-form-element/jsfe",
    "directory": "packages/shoelace"
  },
  "license": "ISC",
  "author": {
    "name": "Julian Cataldo",
    "email": "contact@juliancataldo.com",
    "url": "https://www.juliancataldo.com"
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./*": "./dist/*.js",
    "./*.css": "./dist/*.css",
    "./web-elements": "./dist/_ambient/web-elements.d.ts"
  },
  "files": [
    "./dist",
    "./vscode.html-custom-data.json",
    "./vscode.css-custom-data.json",
    "./custom-elements.json"
  ],
  "scripts": {
    "postinstall": "ts-patch install -s",
    "clean": "rm -rf ./dist",
    "build": "tsc",
    "postbuild": "node --run copy:css && node --run copy:dts",
    "copy:css": "cd ./src && find . -name '*.css' ! -path './themes/webawesome/*' | cpio -pdm ../dist/",
    "copy:dts": "cd src && find . -name '*.d.ts' | cpio -pdm ../dist/",
    "dev": "tsc --watch",
    "wea:generate": "wea-generate"
  },
  "dependencies": {
    "@awesome.me/webawesome": "catalog:",
    "@jsfe/engine": "workspace:*",
    "@jsfe/generics": "workspace:*"
  },
  "peerDependencies": {
    "@lit-labs/signals": "catalog:",
    "lit": "catalog:",
    "react": "catalog:",
    "vue": "catalog:"
  },
  "peerDependenciesMeta": {
    "lit": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "@lit-labs/signals": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@lit/ts-transformers": "^2.0.2",
    "jsx-forge": "0.4.0-next.1",
    "ts-patch": "^3.3.0",
    "typescript": "catalog:",
    "web-elements-analyzer": "0.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "custom-elements": "./custom-elements.json"
}
